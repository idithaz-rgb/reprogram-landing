<script>
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const siblings = Array.from(e.target.parentNode.children);
      const idx = siblings.indexOf(e.target);
      e.target.style.transitionDelay = (idx % 3) * 0.1 + 's';
      e.target.classList.add('on');
      io.unobserve(e.target);
    }
  });
}, {threshold: 0.1});
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

const floatBar = document.getElementById('float-bar');
const hero = document.getElementById('hero');
window.addEventListener('scroll', () => {
  floatBar.classList.toggle('show', window.scrollY > hero.offsetHeight * 0.6);
});

async function submitForm(e) {
  e.preventDefault();
  const btn = document.querySelector('.btn-register');
  const name = e.target.fullname.value;
  const phone = e.target.phone.value;
  const email = e.target.email.value;

  btn.textContent = 'שולחת...';
  btn.disabled = true;

  try {
    await fetch('https://script.google.com/macros/s/AKfycbyYbQQp3UQmkBSuQ8UJa8iRus73aJNapOeBiXJhSEsq9lXAgiw1xmZ_YJU3brKGQ1xz/exec', {
      method: 'POST',
      mode: 'no-cors',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({name: name, phone: phone, email: email, workshop: 'קוד פתוח 27.5.26'})
    });
  } catch(err) {
    console.log('error:', err);
  }

  document.getElementById('reg-form').style.display = 'none';
  document.getElementById('success-msg').style.display = 'block';

  const msg = 'היי אידית, נרשמתי לסדנה קוד פתוח 27.5.26' +
    '%0Aשם: ' + encodeURIComponent(name) +
    '%0Aטלפון: ' + encodeURIComponent(phone) +
    '%0Aאימייל: ' + encodeURIComponent(email);
  document.getElementById('wa-btn').href = 'https://wa.me/972549700108?text=' + msg;
}
</script>
